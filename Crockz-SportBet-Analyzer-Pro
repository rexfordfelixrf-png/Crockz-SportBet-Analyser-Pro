@st.cache_data(ttl=1800)  # 30 minutes
def get_available_sports(_api_key):
    url = f"https://api.the-odds-api.com/v4/sports/?apiKey={_api_key}"
    try:
        data = requests.get(url).json()
        return {s["title"]: s["key"] for s in data if not s.get("has_outrights", True)}
    except:
        return {}

