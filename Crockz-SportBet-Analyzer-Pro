markets = st.multiselect("Markets", ["h2h", "spreads", "totals"], default=["h2h"])

# Simple Poisson helper
def estimate_win_prob(lambda_home, lambda_away, outcome="home"):
    if outcome == "home":
        return sum(poisson.pmf(i, lambda_home) * sum(poisson.pmf(j, lambda_away) for j in range(i)) for i in range(1, 15))
    elif outcome == "away":
        return sum(poisson.pmf(i, lambda_away) * sum(poisson.pmf(j, lambda_home) for j in range(i)) for i in range(1, 15))
    else:  # draw
        return sum(poisson.pmf(i, lambda_home) * poisson.pmf(i, lambda_away) for i in range(10))

if st.button("Fetch & Analyze Odds", type="primary"):
    if not sport_key:
        st.error("No sport selected.")
        st.stop()

    with st.spinner("Fetching live/upcoming odds..."):
        url = (
            f"https://api.the-odds-api.com/v4/sports/{sport_key}/odds/"
            f"?apiKey={odds_api_key}&regions={','.join(regions)}"
            f"&markets={','.join(markets)}&oddsFormat=decimal"
        )
        response = requests.get(url)

        if response.status_code != 200:
            st.error(f"API error: {response.status_code} – {response.text}")
            st.stop()

        data = response.json()
        st.success(f"Found {len(data)} events")

        rows = []
        for event in data:
            home = event["home_team"]
            away = event["away_team"]
            for book in event.get("bookmakers", []):
                for market in book.get("markets", []):
                    for outcome in market.get("outcomes", []):
                        rows.append({
                            "Event": f"{home} vs {away}",
                            "Time": event["commence_time"][:16].replace("T", " "),
                            "Bookmaker": book["title"],
                            "Market": market["key"],
                            "Outcome": outcome["name"],
                            "Odds": outcome["price"],
                            "Implied %": round(100 / outcome["price"], 1) if outcome["price"] > 0 else 0
                        })

        df = pd.DataFrame(rows)
        st.dataframe(df.sort_values(["Event", "Odds"]), use_container_width=True)

        # Best odds summary
        st.subheader("Best Available Odds")
        best = df.groupby(["Event", "Outcome", "Market"])["Odds"].max().reset_index()
        st.dataframe(best, use_container_width=True)

        # Value bet section
        st.subheader("Value Bet Finder")
        event_list = df["Event"].unique()
        selected_event = st.selectbox("Choose match", event_list)

        event_df = df[df["Event"] == selected_event]
        outcomes = event_df["Outcome"].unique()
        selected_outcome = st.selectbox("Outcome to evaluate", options=outcomes)

        best_odds = event_df[event_df["Outcome"] == selected_outcome]["Odds"].max()

        your_prob = st.slider("Your estimated probability (%)", 1, 99, 50, step=1)
        implied_prob = 100 / best_odds if best_odds > 0 else 0
        edge = your_prob - implied_prob

        # Kelly fraction
        if best_odds > 1:
            kelly = (your_prob / 100 - (1 - your_prob / 100) / (best_odds - 1))
            kelly = max(0, kelly)
        else:
            kelly = 0

        st.metric("Edge", f"{edge:+.1f}%")
        st.write(f"**Best odds:** {best_odds:.2f}  |  **Implied prob:** {implied_prob:.1f}%")

        if edge > 5:
            st.success(f"Strong value! Suggested Kelly stake: **{kelly*100:.1f}%** of bankroll")
        elif edge > 0:
            st.info(f"Positive edge. Kelly stake: **{kelly*100:.1f}%**")
        else:
            st.warning("No value at current odds.")

        # Basic Poisson example (placeholder lambdas – improve later with API-SPORTS)
        lambda_home = 1.55
        lambda_away = 1.35
        poisson_home = estimate_win_prob(lambda_home, lambda_away, "home") * 100
        st.info(f"Simple Poisson estimate – Home win: ≈{poisson_home:.1f}%")

        # Export
        st.download_button(
            "Download all odds (CSV)",
            df.to_csv(index=False),
            file_name=f"odds_{sport_key}_{datetime.now().strftime('%Y%m%d_%H%M')}.csv"
        )

