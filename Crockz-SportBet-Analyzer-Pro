# ── Bankroll Management (saved locally in JSON) ─────────────────────────────
BANKROLL_FILE = "bankroll.json"

def load_bankroll():
    if os.path.exists(BANKROLL_FILE):
        with open(BANKROLL_FILE, 'r') as f:
            return json.load(f)
    return {"balance": 1000.0, "history": []}

def save_bankroll(data):
    with open(BANKROLL_FILE, 'w') as f:
        json.dump(data, f)

bankroll = load_bankroll()

st.sidebar.header("💰 Bankroll")
st.sidebar.metric("Balance", f"{bankroll['balance']:.2f} units")
st.sidebar.metric("Bets tracked", len(bankroll['history']))

# Log new bet
with st.sidebar.expander("Log a Placed Bet"):
    bet_event = st.text_input("Event")
    bet_pick = st.text_input("Your selection (e.g. Home Win)")
    odds_taken = st.number_input("Odds taken", min_value=1.01, value=2.00, step=0.05)
    stake = st.number_input("Stake (units)", min_value=0.5, value=10.0, step=1.0)
    
    if st.button("Log Bet"):
        if bet_event and stake > 0:
            bankroll['history'].append({
                "date": datetime.now().strftime("%Y-%m-%d %H:%M"),
                "event": bet_event,
                "pick": bet_pick,
                "odds": odds_taken,
                "stake": stake,
                "result": None,
                "profit": None
            })
            bankroll['balance'] -= stake
            save_bankroll(bankroll)
            st.success("Bet logged. Update result later when settled.")
        else:
            st.error("Enter event and stake.")

# Update result
with st.sidebar.expander("Update Bet Result"):
    pending_bets = [i for i, b in enumerate(bankroll['history']) if b['result'] is None]
    if pending_bets:
        idx = st.selectbox("Select unsettled bet", pending_bets,
                           format_func=lambda i: f"{bankroll['history'][i]['date']} – {bankroll['history'][i]['event']}")
        result = st.radio("Outcome", ["Win", "Loss", "Push"])
        if st.button("Save Result"):
            bet = bankroll['history'][idx]
            if result == "Win":
                profit = bet['stake'] * (bet['odds'] - 1)
            elif result == "Loss":
                profit = -bet['stake']
            else:  # Push
                profit = 0
            bankroll['balance'] += bet['stake'] + profit
            bet['result'] = result
            bet['profit'] = profit
            save_bankroll(bankroll)
            st.success(f"Result saved. Profit: {profit:+.2f} | New balance: {bankroll['balance']:.2f}")
    else:
        st.info("No unsettled bets.")

# Simple ROI
closed_bets = [b for b in bankroll['history'] if b['result']]
if closed_bets:
    total_stake = sum(b['stake'] for b in closed_bets)
    total_profit = sum(b.get('profit', 0) for b in closed_bets)
    roi = (total_profit / total_stake) * 100 if total_stake > 0 else 0
    st.sidebar.metric("ROI (closed bets)", f"{roi:.1f}%")

